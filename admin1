<!DOCTYPE html>
<html lang="id" class="bg-[#f3f4f9]">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>RM Pangkalan | Enterprise Owner Center v23.0</title>
    
    <!-- PWA Meta -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#7c3aed">
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/3448/3448609.png">

    <!-- Frameworks -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap');
        :root { --primary: #7c3aed; --bg: #f3f4f9; }
        
        html, body { background-color: var(--bg) !important; margin: 0; padding: 0; overflow: hidden; height: 100%; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; color: #1e293b; -webkit-tap-highlight-color: transparent; }

        /* Sidebar Desktop - Fixed Height & Absolute Clarity */
        .sidebar-fixed { 
            background: var(--primary); border-radius: 0 45px 45px 0; 
            height: 100vh !important; width: 280px;
            position: fixed; top: 0; left: 0; z-index: 1000;
            box-shadow: 15px 0 40px rgba(124, 58, 237, 0.1);
        }
        .nav-item { color: rgba(255,255,255,0.45); transition: 0.3s; border-radius: 22px; cursor: pointer; display: flex; align-items: center; margin-bottom: 10px; }
        .nav-item:hover { color: white; background: rgba(255,255,255,0.08); }
        .nav-item.active { background: white; color: var(--primary); box-shadow: 0 15px 35px rgba(0,0,0,0.12); font-weight: 800; }
        
        /* Enterprise Components */
        .card-ent { background: white; border-radius: 35px; border: 1.5px solid #f1f5f9; box-shadow: 0 20px 40px -15px rgba(0,0,0,0.04); overflow: hidden; transition: 0.3s; }
        .card-ent:hover { transform: translateY(-4px); }

        /* Mobile Pill Nav - Pure Floating Zero Bleed */
        .bottom-pill-nav {
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
            width: 92%; max-width: 440px; background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.6);
            height: 76px; z-index: 9999; border-radius: 38px;
            box-shadow: 0 25px 60px -15px rgba(124, 58, 237, 0.3);
            display: flex; align-items: center; justify-content: space-around; padding: 0 10px;
        }

        .tab-pill {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            gap: 2px; color: #94a3b8; font-weight: 800; font-size: 8px; text-transform: uppercase;
            width: 60px; height: 56px; border-radius: 24px; transition: 0.3s;
        }
        .tab-pill.active { color: var(--primary); background: rgba(124, 58, 237, 0.08); }

        /* Modal UI / Swiper Pro */
        .swal2-popup.detail-modal { border-radius: 45px !important; padding: 1.2rem 0.05rem !important; width: 98% !important; max-width: 600px !important; }
        .input-pro { width: 100%; background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 18px; padding: 14px 20px; font-size: 14px; font-weight: 600; outline: none; transition: 0.2s; }
        .input-pro:focus { border-color: var(--primary); background: white; box-shadow: 0 0 0 5px rgba(124, 58, 237, 0.05); }

        .upload-zone { border: 2.5px dashed #e2e8f0; border-radius: 26px; padding: 25px; text-align: center; cursor: pointer; background: #fbfcfe; transition: 0.3s; }
        .upload-zone:hover { border-color: var(--primary); background: #f5f3ff; }

        @media (min-width: 769px) { .main-canvas { margin-left: 280px; width: calc(100% - 280px); } }
        @media (max-width: 768px) {
            #mainSidebar { display: none !important; }
            .main-canvas { padding-bottom: 140px !important; width: 100vw !important; margin: 0 !important; background-color: var(--bg) !important; }
            .mobile-px-min { padding-left: 0.75rem !important; padding-right: 0.75rem !important; }
        }

        /* Focus & Blur Layering */
        .blur-target[inert] { filter: blur(15px); opacity: 0.25; pointer-events: none; transition: 0.4s; }
        #loginOverlay[inert] { display: none !important; }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .animate-pop { animation: pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes pop { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); } }
        
        .ai-glow-btn { background: linear-gradient(135deg, #7c3aed, #4f46e5); color: white; padding: 10px 20px; border-radius: 16px; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; box-shadow: 0 10px 20px rgba(124, 58, 237, 0.2); transition: 0.3s; }
        .ai-glow-btn:hover { transform: scale(1.05); }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <!-- SECURITY SCREEN -->
    <div id="loginOverlay" class="fixed inset-0 bg-violet-600 z-[10001] flex items-center justify-center p-4">
        <div class="bg-white p-12 rounded-[65px] shadow-2xl w-full max-w-md text-center animate-pop">
            <div class="bg-violet-100 w-24 h-24 rounded-[40px] flex items-center justify-center mx-auto mb-8 shadow-sm">
                <i data-lucide="shield-check" class="text-violet-600 w-12 h-12"></i>
            </div>
            <h2 class="text-3xl font-black italic tracking-tighter text-slate-800 mb-2 uppercase">OWNER ACCESS</h2>
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[2px] mb-12 italic">Secure Management System v23.0</p>
            <div class="space-y-4">
                <input type="text" id="loginUser" placeholder="Username" class="input-pro">
                <input type="password" id="loginPass" placeholder="Password" class="input-pro">
                <button onclick="handleLogin()" id="loginBtn" class="w-full bg-violet-600 text-white py-5 rounded-[26px] font-black text-xs uppercase italic tracking-widest shadow-xl shadow-violet-200 active:scale-95 transition-all mt-6 uppercase tracking-widest">Otorisasi Panel</button>
            </div>
        </div>
    </div>

    <!-- DESKTOP SIDEBAR -->
    <aside id="mainSidebar" class="hidden md:flex flex-col sidebar-fixed text-white p-10">
        <div class="mb-16">
            <span class="text-3xl font-black italic uppercase block tracking-tighter leading-none">PANGKALAN</span>
            <span class="text-[10px] font-bold uppercase tracking-[5px] opacity-50 mt-1 block">Enterprise</span>
        </div>
        <nav class="flex-1 space-y-4 overflow-y-auto no-scrollbar pb-10">
            <div onclick="switchTab('dashboard')" id="nav-dashboard" class="nav-item active p-4 gap-5 transition-all"><i data-lucide="layout-dashboard"></i> <span class="text-[11px] uppercase tracking-widest font-black">Dashboard</span></div>
            <div onclick="switchTab('menu')" id="nav-menu" class="nav-item p-4 gap-5 transition-all"><i data-lucide="utensils"></i> <span class="text-[11px] uppercase tracking-widest font-black">Menu Master</span></div>
            <div onclick="switchTab('sales')" id="nav-sales" class="nav-item p-4 gap-5 transition-all"><i data-lucide="file-text"></i> <span class="text-[11px] uppercase tracking-widest font-black">Sales Report</span></div>
            <div onclick="switchTab('staff')" id="nav-staff" class="nav-item p-4 gap-5 transition-all"><i data-lucide="users"></i> <span class="text-[11px] uppercase tracking-widest font-black">HR & SDM</span></div>
            <div onclick="switchTab('audit')" id="nav-audit" class="nav-item p-4 gap-5 transition-all"><i data-lucide="activity"></i> <span class="text-[11px] uppercase tracking-widest font-black">Audit Logs</span></div>
        </nav>
        <div class="mt-auto pt-10 border-t border-white/10">
            <button onclick="handleLogout()" class="w-full bg-white/10 p-5 rounded-3xl font-black text-[10px] uppercase hover:bg-white/20 transition-all text-white">Logout System</button>
        </div>
    </aside>

    <!-- MOBILE PILL NAV -->
    <nav id="mobilePillNav" class="md:hidden bottom-pill-nav">
        <button onclick="switchTab('dashboard')" id="pill-dashboard" class="tab-pill active"><i data-lucide="home" class="w-6 h-6"></i><span>DASH</span></button>
        <button onclick="switchTab('menu')" id="pill-menu" class="tab-pill"><i data-lucide="utensils" class="w-6 h-6"></i><span>MENU</span></button>
        <button onclick="switchTab('sales')" id="pill-sales" class="tab-pill"><i data-lucide="file-text" class="w-6 h-6"></i><span>SALES</span></button>
        <button onclick="switchTab('audit')" id="pill-audit" class="tab-pill"><i data-lucide="activity" class="w-6 h-6"></i><span>LOGS</span></button>
        <button onclick="handleLogout()" class="tab-pill text-red-400"><i data-lucide="log-out" class="w-6 h-6"></i><span>EXIT</span></button>
    </nav>

    <!-- MAIN CANVAS -->
    <main id="mainContent" class="hidden flex-1 flex flex-col min-w-0 overflow-hidden main-canvas blur-target" style="background-color: var(--bg);">
        <header class="h-20 md:h-24 px-6 md:px-12 flex items-center justify-between flex-shrink-0 bg-white/90 backdrop-blur-md border-b border-slate-100">
            <div class="flex items-center gap-4">
                <div class="md:hidden bg-violet-600 text-white w-12 h-12 rounded-2xl flex items-center justify-center font-black italic text-xs shadow-lg">RM</div>
                <div>
                    <h1 id="tabTitle" class="text-xl md:text-2xl font-black text-slate-800 italic uppercase tracking-tighter leading-none">DASHBOARD</h1>
                    <div class="flex items-center gap-2 mt-1">
                        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                        <span id="digitalClock" class="text-[10px] font-black text-slate-400 tracking-widest uppercase">00:00:00 - Online</span>
                    </div>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <button onclick="syncData(true)" class="p-3 bg-slate-50 rounded-2xl text-violet-600 border border-slate-100 active:rotate-180 transition-all hover:bg-white"><i data-lucide="refresh-cw" class="w-5 h-5"></i></button>
                <div class="w-12 md:w-16 h-12 md:h-16 rounded-[24px] bg-slate-900 flex items-center justify-center text-white font-black text-sm shadow-xl" id="userInitial">OW</div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto no-scrollbar mobile-px-min p-4 md:p-12 space-y-8">
            
            <!-- SECTION: DASHBOARD -->
            <div id="section-dashboard" class="space-y-8 animate-pop">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                    <div class="card-ent p-8 border-l-[15px] border-violet-600"><p class="text-[10px] font-black text-slate-400 uppercase italic mb-1">Total Omzet</p><h2 id="stat-revenue" class="text-2xl md:text-3xl font-black text-slate-800 italic leading-none tracking-tighter">Rp 0</h2></div>
                    <div class="card-ent p-8 border-l-[15px] border-orange-500"><p class="text-[10px] font-black text-slate-400 uppercase italic mb-1">Laba Bersih (AI)</p><h2 id="stat-profit" class="text-2xl md:text-3xl font-black text-slate-800 italic leading-none tracking-tighter">Rp 0</h2></div>
                    <div class="card-ent p-8 border-l-[15px] border-blue-500"><p class="text-[10px] font-black text-slate-400 uppercase italic mb-1">Transaksi Berhasil</p><h2 id="stat-orders" class="text-2xl md:text-3xl font-black text-slate-800 italic leading-none tracking-tighter">0</h2></div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <section class="card-ent p-10 bg-gradient-to-br from-violet-900 to-black text-white relative overflow-hidden group">
                        <i data-lucide="sparkles" class="absolute -right-6 -bottom-6 w-32 h-32 opacity-10"></i>
                        <h3 class="text-sm font-black uppercase tracking-widest italic mb-4">Gemini Business AI Intelligence</h3>
                        <p class="text-[11px] text-violet-200 mb-8 leading-relaxed uppercase font-bold italic">Analisalah riwayat penjualan dan pengeluaran harian untuk strategi promosi yang lebih cerdas.</p>
                        <button onclick="analyzeBusinessAI()" class="w-full bg-white/10 hover:bg-white text-white hover:text-violet-900 py-4 rounded-3xl font-black text-[11px] uppercase transition-all shadow-xl">✨ JALANKAN ANALISA AI</button>
                    </section>
                    <section class="card-ent p-10"><h3 class="text-xs font-black text-slate-800 uppercase tracking-widest mb-6 italic border-b pb-4">Loyal Customers</h3><div id="topCustomers" class="space-y-3"></div></section>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <section class="card-ent p-10 bg-slate-900 text-white">
                        <h3 class="text-xs font-black uppercase tracking-widest mb-4 italic leading-none">Journal Digital</h3>
                        <div class="flex gap-4">
                            <button onclick="exportToExcel()" class="flex-1 bg-green-600 py-4 rounded-3xl font-black text-[11px] uppercase shadow-lg">XLSX Export</button>
                            <button onclick="exportToPDF()" class="flex-1 bg-red-600 py-4 rounded-3xl font-black text-[11px] uppercase shadow-lg">PDF Journal</button>
                        </div>
                    </section>
                    <section class="card-ent p-10">
                        <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest mb-6 italic">Pengaturan Cloud</h3>
                        <div class="space-y-4">
                            <input type="text" id="apiInput" class="input-pro" placeholder="API Apps Script URL">
                            <input type="text" id="folderIdInput" class="input-pro" placeholder="Folder ID Media G-Drive">
                            <button onclick="saveConfig()" class="w-full bg-violet-600 text-white py-4 rounded-3xl font-black text-[11px] uppercase active:scale-95 transition-all">SINKRONKAN PARAMETER</button>
                        </div>
                    </section>
                </div>
            </div>

            <!-- SECTION: MENU LIST (Refactored Grid) -->
            <div id="section-menu" class="hidden animate-pop space-y-6">
                 <div class="p-8 md:p-10 card-ent flex items-center justify-between bg-white">
                    <div><h3 class="text-lg md:text-xl font-black text-slate-800 uppercase italic">Katalog Master</h3><p class="text-[10px] font-bold text-slate-400 uppercase mt-1 italic">Produk, HPP, & Media Asset</p></div>
                    <button onclick="openMenuForm()" class="bg-slate-900 text-white px-8 py-4 rounded-3xl font-black text-[11px] uppercase shadow-lg">+ PRODUK</button>
                </div>
                <div id="menuFullList" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6"></div>
            </div>

            <!-- SECTION: SALES -->
            <div id="section-sales" class="hidden animate-pop space-y-6">
                <div class="p-8 md:p-10 card-ent flex justify-between items-center bg-white">
                    <div><h3 class="text-lg md:text-xl font-black text-slate-800 uppercase italic leading-none">Sales Journal</h3><p class="text-[10px] font-bold text-slate-400 uppercase mt-2 italic tracking-widest">Verified Transactions Only</p></div>
                    <button onclick="openExpenseForm()" class="bg-red-500 text-white px-6 py-4 rounded-3xl font-black text-[10px] uppercase shadow-lg shadow-red-100">+ BIAYA OPERASIONAL</button>
                </div>
                <div id="salesListContainer" class="divide-y divide-slate-50 card-ent bg-white max-h-[60vh] overflow-y-auto no-scrollbar px-4"></div>
            </div>

            <!-- SECTION: STAFF -->
            <div id="section-staff" class="hidden animate-pop space-y-6">
                 <div class="p-8 md:p-10 card-ent flex items-center justify-between bg-white">
                    <h3 class="text-lg md:text-xl font-black text-slate-800 uppercase italic leading-none">Resources Management</h3>
                    <button onclick="openStaffForm()" class="bg-violet-600 text-white px-8 py-4 rounded-3xl font-black text-[11px] uppercase shadow-lg">+ TAMBAH STAFF</button>
                </div>
                <div id="staffListContainer" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6"></div>
            </div>

            <!-- SECTION: AUDIT LOGS -->
            <div id="section-audit" class="hidden animate-pop space-y-6">
                <div class="p-8 md:p-10 card-ent bg-white">
                    <h3 class="text-xs font-black text-slate-800 uppercase tracking-[3px] mb-8 italic border-b pb-4">Audit Trail (Log Aktifitas Terakhir)</h3>
                    <div id="auditLogs" class="space-y-2 max-h-[70vh] overflow-y-auto no-scrollbar"></div>
                </div>
            </div>

        </div>
    </main>

    <script>
        const apiKey = ""; 
        let DEFAULT_API = 'https://script.google.com/macros/s/AKfycbxbOjRecwa41sC0QAqkMoCOYKm5-YLM9nZRpnXiYDghZkuNe7RJohWXUx56EHM3Von4AQ/exec';
        let API_URL = localStorage.getItem('RM_API_URL') || DEFAULT_API;
        let FOLDER_ID = localStorage.getItem('RM_FOLDER_ID') || '';
        let DB = { menu: [], transactions: [], users: [], expenses: [], logs: [], customers: [] };

        window.onload = () => {
            lucide.createIcons(); checkAuth();
            setInterval(() => { document.getElementById('digitalClock').innerText = new Date().toLocaleTimeString('id-ID', {hour12:false}) + ' - Online'; }, 1000);
            document.getElementById('apiInput').value = API_URL;
            document.getElementById('folderIdInput').value = FOLDER_ID;
        };

        function setModalEffect(active) {
            const main = document.getElementById('mainContent');
            if(active) main.setAttribute('inert', ''); else main.removeAttribute('inert');
        }

        async function handleLogin() {
            const user = document.getElementById('loginUser').value.trim();
            const pass = document.getElementById('loginPass').value.trim();
            if(!user || !pass) return Swal.fire('Oops!', 'Lengkapi Username & Password.', 'warning');
            
            Swal.fire({ title: 'Otentikasi...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const res = await fetch(`${API_URL}?action=getData`);
                const data = await res.json();
                const valid = data.users.find(u => u.Username.toLowerCase() === user.toLowerCase() && String(u.Password) === pass && u.Role === 'Owner');
                if (valid) {
                    sessionStorage.setItem('ADMIN_AUTH', valid.Username);
                    checkAuth(); Swal.close();
                } else { Swal.fire('Akses Ditolak', 'Kredensial salah atau bukan Owner.', 'error'); }
            } catch (e) { Swal.fire('Error', 'Gagal hubungi server cloud.', 'error'); }
        }

        function checkAuth() {
            const user = sessionStorage.getItem('ADMIN_AUTH');
            const overlay = document.getElementById('loginOverlay');
            if (user) {
                overlay.style.display = 'none'; overlay.setAttribute('inert', '');
                document.getElementById('mainContent').classList.remove('hidden');
                document.getElementById('mainSidebar').classList.remove('hidden');
                document.getElementById('userInitial').innerText = user.slice(0,2).toUpperCase();
                syncData(true);
            } else { overlay.style.display = 'flex'; document.getElementById('mainContent').classList.add('hidden'); }
        }

        function switchTab(tab) {
            ['dashboard', 'menu', 'sales', 'staff', 'audit'].forEach(t => {
                const sec = document.getElementById(`section-${t}`);
                if(sec) sec.classList.toggle('hidden', t !== tab);
                document.getElementById(`nav-${t}`)?.classList.toggle('active', t === tab);
                document.getElementById(`pill-${t}`)?.classList.toggle('active', t === tab);
            });
            document.getElementById('tabTitle').innerText = tab.toUpperCase();
            lucide.createIcons();
        }

        async function syncData(loader = false) {
            if(loader) Swal.fire({ title: 'Turbo Sync Aktif...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const res = await fetch(`${API_URL}?action=getData`);
                DB = await res.json();
                renderStats(); renderMenu(); renderStaff(); renderSales(); renderLogs(); renderCRM();
                if(loader) Swal.close();
            } catch (e) { if(loader) Swal.fire('Offline', 'Sinkronisasi Gagal.', 'error'); }
        }

        function renderStats() {
            const rev = DB.transactions.reduce((s, t) => s + (t.Status !== 'Pending' ? Number(t.Total) : 0), 0);
            const exp = DB.expenses ? DB.expenses.reduce((s, e) => s + Number(e.Amount), 0) : 0;
            document.getElementById('stat-revenue').innerText = `Rp ${rev.toLocaleString()}`;
            document.getElementById('stat-profit').innerText = `Rp ${(rev - exp).toLocaleString()}`;
            document.getElementById('stat-orders').innerText = DB.transactions.length;
        }

        function renderCRM() {
            const cont = document.getElementById('topCustomers');
            if(!cont || !DB.customers) return;
            const sorted = [...DB.customers].sort((a,b) => b.Visits - a.Visits).slice(0, 5);
            cont.innerHTML = sorted.map(c => `
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-white">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center text-violet-600 font-black text-xs">${c.Name.slice(0,1)}</div>
                        <div><p class="text-[11px] font-black text-slate-700 uppercase italic">${c.Name}</p><p class="text-[9px] text-slate-400 font-bold">${c.Phone}</p></div>
                    </div>
                    <span class="bg-violet-600 text-white text-[9px] font-black px-3 py-1.5 rounded-xl leading-none">${c.Visits}x Visit</span>
                </div>`).join('');
        }

        function renderMenu() {
            const list = document.getElementById('menuFullList');
            list.innerHTML = DB.menu.map(m => `
                <div class="card-ent bg-white p-6 flex flex-col gap-4 animate-pop">
                    <div class="relative w-full aspect-video rounded-[24px] overflow-hidden bg-slate-50 border-2 border-slate-50 shadow-inner">
                        <img src="${m.Img}" class="w-full h-full object-cover" onerror="this.src='https://placehold.co/400x300?text=Produk'">
                        <div class="absolute top-3 left-3 bg-white/90 backdrop-blur px-3 py-1.5 rounded-xl font-black text-[9px] uppercase italic text-violet-600 shadow-sm">${m.Category}</div>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-black text-slate-800 text-base uppercase italic leading-none mb-1 truncate">${m.Name}</h4>
                        <div class="flex items-center gap-3 mt-3">
                            <span class="text-[13px] font-black text-violet-600 italic">Rp ${Number(m.Price).toLocaleString()}</span>
                            <span class="text-[10px] font-bold text-slate-300 italic">HPP: ${Number(m.HPP || 0).toLocaleString()}</span>
                        </div>
                    </div>
                    <div class="flex gap-2 pt-4 border-t border-slate-50">
                        <button onclick="openMenuForm('${m.ID}')" class="flex-1 py-3 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400 active:scale-95 transition-all hover:bg-violet-50 hover:text-violet-600"><i data-lucide="edit-3" class="w-4 h-4 mr-2"></i> <span class="text-[10px] font-black uppercase">Edit</span></button>
                        <button onclick="deleteData('Menu', '${m.ID}')" class="w-12 h-12 bg-red-50 rounded-2xl flex items-center justify-center text-red-400 active:scale-95 hover:bg-red-500 hover:text-white transition-all"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    </div>
                </div>`).join('');
            lucide.createIcons();
        }

        function renderStaff() {
            const list = document.getElementById('staffListContainer');
            list.innerHTML = DB.users.map(u => `
                <div class="card-ent bg-white p-6 flex items-center gap-5 animate-pop">
                    <img src="${u.Img || 'https://ui-avatars.com/api/?name='+u.Username}" class="w-16 h-16 rounded-[22px] border-2 border-slate-50 object-cover shadow-sm">
                    <div class="flex-1 min-w-0">
                        <h4 class="font-black text-slate-800 text-sm uppercase italic truncate leading-none">${u.Username}</h4>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1.5">${u.Role}</p>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <button onclick="openStaffForm('${u.Username}')" class="p-3 bg-slate-50 rounded-xl text-slate-400 active:scale-95 hover:text-violet-600 transition-all"><i data-lucide="settings" class="w-4 h-4"></i></button>
                        <button onclick="deleteData('User', '${u.Username}')" class="p-3 bg-red-50 rounded-xl text-red-400 active:scale-95 hover:bg-red-500 hover:text-white transition-all"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    </div>
                </div>`).join('');
            lucide.createIcons();
        }

        function renderSales() {
            const container = document.getElementById('salesListContainer');
            container.innerHTML = DB.transactions.slice().reverse().map(t => `
                <div class="py-6 flex flex-col gap-3 hover:bg-slate-50/50 transition-all px-2">
                    <div class="flex justify-between items-start">
                        <div><span class="text-[8px] font-black text-slate-300 uppercase tracking-widest">TRX #${t.ID.slice(-6)}</span><h4 class="text-sm font-black text-slate-800 uppercase italic mt-1 leading-none">${t.Customer || t.Role}</h4></div>
                        <span class="font-black text-violet-600 text-base italic tracking-tighter leading-none">Rp ${Number(t.Total).toLocaleString()}</span>
                    </div>
                    <p class="text-[11px] font-bold text-slate-500 uppercase italic opacity-70 leading-relaxed">${t.Items}</p>
                    <div class="flex items-center gap-3 text-[9px] font-black uppercase italic text-slate-300 pt-2 border-t border-slate-50 border-dashed mt-1">
                        <span><i data-lucide="calendar" class="w-3 h-3 inline mr-1"></i>${new Date(t.Date).toLocaleDateString()}</span>
                        <span>|</span>
                        <span>${t.Type}</span>
                    </div>
                </div>`).join('');
            lucide.createIcons();
        }

        function renderLogs() {
            const cont = document.getElementById('auditLogs');
            if(!DB.logs) return;
            cont.innerHTML = DB.logs.map(l => `
                <div class="text-[10px] p-4 bg-slate-50 rounded-2xl border border-white flex gap-4 items-center">
                    <span class="font-bold text-slate-400 w-24 flex-shrink-0">${new Date(l.Timestamp).toLocaleTimeString()}</span>
                    <span class="font-black text-violet-600 w-20 uppercase flex-shrink-0 truncate">${l.User}</span>
                    <div class="flex-1 font-bold text-slate-700 italic border-l pl-4">${l.Action}: ${l.Detail}</div>
                </div>`).join('');
        }

        async function openExpenseForm() {
            setModalEffect(true);
            const { value: form } = await Swal.fire({
                title: '<span class="italic font-black text-xl uppercase">Operasional Biaya</span>',
                html: `<div class="space-y-4 p-2 text-left">
                    <input id="ex-cat" class="input-pro" placeholder="Kategori (Belanja, Listrik, Gaji)">
                    <input id="ex-amt" type="number" class="input-pro" placeholder="Nominal (Rp)">
                    <textarea id="ex-note" class="input-pro h-24 pt-4 resize-none" placeholder="Detail Biaya..."></textarea>
                </div>`,
                showCancelButton: true, confirmButtonColor: '#7c3aed', customClass: { popup: 'detail-modal' },
                preConfirm: () => ({ action: 'addExpense', category: document.getElementById('ex-cat').value, amount: document.getElementById('ex-amt').value, note: document.getElementById('ex-note').value, operator: sessionStorage.getItem('ADMIN_AUTH') })
            });
            setModalEffect(false);
            if(form) { await fetch(API_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(form) }); syncData(true); }
        }

        async function openMenuForm(id = null) {
            setModalEffect(true);
            const item = id ? DB.menu.find(m => m.ID == id) : { ID: 'M'+Date.now().toString().slice(-6), Name:'', Category:'', Price:0, Description:'', Img:'', HPP: 0 };
            const { value: form } = await Swal.fire({
                title: `<span class="italic font-black text-xl uppercase">${id ? 'Update Menu' : 'Produk Baru'}</span>`,
                html: `<div class="space-y-4 p-2 text-left overflow-y-auto no-scrollbar max-h-[70vh]">
                    <input id="m-name" class="input-pro" value="${item.Name}" placeholder="Nama Produk">
                    <div class="grid grid-cols-2 gap-4">
                        <div><label class="text-[9px] font-black uppercase text-slate-400 ml-2">Harga Jual</label>
                        <input id="m-price" type="number" class="input-pro mt-1" value="${item.Price}"></div>
                        <div><label class="text-[9px] font-black uppercase text-slate-400 ml-2">HPP (Modal)</label>
                        <input id="m-hpp" type="number" class="input-pro mt-1" value="${item.HPP || 0}"></div>
                    </div>
                    <input id="m-cat" class="input-pro" value="${item.Category}" placeholder="Kategori Menu (Ketik Baru)">
                    <div class="flex justify-between items-center px-1">
                        <label class="text-[9px] font-black uppercase text-slate-400">Deskripsi Pemasaran</label>
                        <button onclick="suggestMenuAI()" class="ai-glow-btn">✨ AI ASSIST</button>
                    </div>
                    <textarea id="m-desc" class="input-pro h-24 pt-4 resize-none leading-relaxed">${item.Description || ''}</textarea>
                    <div class="upload-zone" onclick="document.getElementById('f-menu').click()">
                        <input type="file" id="f-menu" class="hidden" onchange="handleFileUpload(this, 'p-menu', 'v-menu')">
                        <div id="p-menu">
                            ${item.Img ? `<img src="${item.Img}" class="w-24 h-24 mx-auto rounded-[22px] object-cover shadow-lg border-2 border-white">` : '<i data-lucide="image-plus" class="w-10 h-10 mx-auto text-slate-200"></i><p class="text-[9px] font-black text-slate-400 mt-2 uppercase">Unggah Foto Produk</p>'}
                        </div>
                    </div>
                    <input id="v-menu" type="hidden" value="${item.Img}">
                </div>`,
                showCancelButton: true, confirmButtonColor: '#7c3aed', customClass: { popup: 'detail-modal' },
                preConfirm: () => ({ action: 'updateMenu', id: item.ID, name: document.getElementById('m-name').value, category: document.getElementById('m-cat').value, price: document.getElementById('m-price').value, hpp: document.getElementById('m-hpp').value, img: document.getElementById('v-menu').value, description: document.getElementById('m-desc').value, folderId: FOLDER_ID, operator: sessionStorage.getItem('ADMIN_AUTH') })
            });
            setModalEffect(false);
            if(form) { Swal.fire({ title: 'Menyimpan Cloud...', didOpen: () => Swal.showLoading() }); await fetch(API_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(form) }); syncData(true); }
        }

        async function handleFileUpload(input, pid, vid) {
            const file = input.files[0]; if(!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                document.getElementById(vid).value = e.target.result;
                document.getElementById(pid).innerHTML = `<img src="${e.target.result}" class="w-24 h-24 mx-auto rounded-[22px] object-cover border-4 border-violet-500 shadow-xl animate-pop">`;
            };
            reader.readAsDataURL(file);
        }

        async function analyzeBusinessAI() {
            const sum = `Omzet: ${document.getElementById('stat-revenue').innerText}, Laba: ${document.getElementById('stat-profit').innerText}, Total Transaksi: ${DB.transactions.length}, Staff Aktif: ${DB.users.length}`;
            Swal.fire({ title: 'AI sedang menganalisa...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            const response = await callGeminiAI(`Analisa bisnis RM Pangkalan ini: ${sum}. Berikan 3 strategi pertumbuhan tajam dalam Bahasa Indonesia.`, "Anda adalah Konsultan Bisnis Enterprise.");
            Swal.fire({ title: '<span class="italic font-black text-xl uppercase">AI Business Report</span>', html: `<div class="text-left text-sm leading-relaxed p-4 bg-slate-50 rounded-3xl border italic font-medium">${response.replace(/\n/g, '<br>')}</div>`, confirmButtonColor: '#7c3aed', customClass: { popup: 'detail-modal' } });
        }

        async function suggestMenuAI() {
            const name = document.getElementById('m-name').value;
            if(!name) return Swal.fire('Oops', 'Tulis nama menu dulu.', 'warning');
            const response = await callGeminiAI(`Tulis deskripsi menu "${name}" yang menggiurkan (maks 15 kata). Berikan rekomendasi harga jual Rupiah yang masuk akal.`, "Anda adalah Culinary Copywriter.");
            document.getElementById('m-desc').value = response;
            Swal.fire({ icon: 'success', title: '✨ Deskripsi AI Siap', timer: 1000, showConfirmButton: false });
        }

        async function callGeminiAI(prompt, sys) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            try {
                const res = await fetch(url, { method: 'POST', body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }], systemInstruction: { parts: [{ text: sys }] } }) });
                const result = await res.json();
                return result.candidates?.[0]?.content?.parts?.[0]?.text || "AI sibuk.";
            } catch (e) { return "Koneksi Gemini Putus."; }
        }

        async function openStaffForm(user = null) {
            setModalEffect(true);
            const staff = user ? DB.users.find(u => u.Username === user) : { Username: '', Password: '', Role: 'Waiters', FullName: '', NIK: '', Phone: '', Img: '' };
            const { value: form } = await Swal.fire({
                title: `<span class="italic font-black text-xl uppercase">Profile Staff</span>`,
                html: `<div class="space-y-4 p-2 text-left">
                    <input id="s-user" class="input-pro" placeholder="Username / ID" value="${staff.Username}" ${user ? 'readonly' : ''}>
                    <input id="s-fname" class="input-pro" placeholder="Nama Lengkap" value="${staff.FullName || ''}">
                    <div class="grid grid-cols-2 gap-4"><input id="s-nik" class="input-pro" placeholder="NIK KTP"><input id="s-phone" class="input-pro" placeholder="WhatsApp"></div>
                    <input id="s-pass" type="text" class="input-pro" placeholder="PIN Akses" value="${staff.Password}">
                    <select id="s-role" class="input-pro"><option value="Owner" ${staff.Role=='Owner'?'selected':''}>Owner (Penuh)</option><option value="Kasir" ${staff.Role=='Kasir'?'selected':''}>Kasir (POS)</option><option value="Waiters" ${staff.Role=='Waiters'?'selected':''}>Waiters</option><option value="Koki" ${staff.Role=='Koki'?'selected':''}>Koki</option></select>
                    <div class="upload-zone" onclick="document.getElementById('f-staff').click()">
                        <input type="file" id="f-staff" class="hidden" onchange="handleFileUpload(this, 'p-staff', 'v-staff')">
                        <div id="p-staff">
                            ${staff.Img ? `<img src="${staff.Img}" class="w-24 h-24 mx-auto rounded-[22px] object-cover shadow-lg border-2 border-white">` : '<i data-lucide="camera" class="w-10 h-10 mx-auto text-slate-200"></i><p class="text-[9px] font-black text-slate-400 mt-2 uppercase">Ganti Foto Profil</p>'}
                        </div>
                    </div>
                    <input id="v-staff" type="hidden" value="${staff.Img}">
                </div>`,
                showCancelButton: true, confirmButtonColor: '#7c3aed', customClass: { popup: 'detail-modal' },
                preConfirm: () => ({ action: 'updateUser', username: document.getElementById('s-user').value, fullName: document.getElementById('s-fname').value, nik: document.getElementById('s-nik').value, phone: document.getElementById('s-phone').value, password: document.getElementById('s-pass').value, role: document.getElementById('s-role').value, img: document.getElementById('v-staff').value, folderId: FOLDER_ID, operator: sessionStorage.getItem('ADMIN_AUTH') })
            });
            setModalEffect(false);
            if(form) { await fetch(API_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(form) }); syncData(true); }
        }

        function saveConfig() {
            const u = document.getElementById('apiInput').value.trim();
            const f = document.getElementById('folderIdInput').value.trim();
            localStorage.setItem('RM_API_URL', u); API_URL = u;
            localStorage.setItem('RM_FOLDER_ID', f); FOLDER_ID = f;
            Swal.fire({ icon: 'success', title: 'Config Lock', text: 'ID Folder & API tersimpan permanen.', timer: 1500, showConfirmButton: false });
            syncData(true);
        }

        async function deleteData(type, id) {
            const { isConfirmed } = await Swal.fire({ title: `Hapus ${type}?`, text: "Data hilang permanen dari sistem.", icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444' });
            if(isConfirmed) {
                const action = type === 'Menu' ? 'deleteMenu' : 'deleteUser';
                const payload = type === 'Menu' ? { action, id, operator: sessionStorage.getItem('ADMIN_AUTH') } : { action, username: id, operator: sessionStorage.getItem('ADMIN_AUTH') };
                await fetch(API_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(payload) });
                syncData(true); 
            }
        }

        function handleLogout() { sessionStorage.removeItem('ADMIN_AUTH'); location.reload(); }
        function exportToExcel() { const ws = XLSX.utils.json_to_sheet(DB.transactions); const wb = XLSX.utils.book_new(); XLSX.utils.book_append_sheet(wb, ws, "Sales"); XLSX.writeFile(wb, `POS_REPORT_${new Date().getTime()}.xlsx`); }
        async function exportToPDF() { const { jsPDF } = window.jspdf; const doc = new jsPDF(); doc.text("PANGKALAN ENTERPRISE - SALES REPORT", 14, 15); const body = DB.transactions.map(t => [t.ID.slice(-4), t.Customer || t.Role, t.Total, t.Type]); doc.autoTable({ head: [['ID', 'Cust', 'Total', 'Payment']], body: body, startY: 25, headStyles: {fillColor:[124, 58, 237]} }); doc.save(`Sales_Report.pdf`); }
    </script>
</body>
</html>
